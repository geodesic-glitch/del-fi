# --- Runtime state: per-deployment, never commit ---
vectorstore/
wiki/
cache/
gossip/
seen_senders.txt
conversation_memory.json
board.json
*.log

# --- Config: user-specific, contains local paths ---
# Commit config.example.yaml instead. See examples/ for deployment templates.
config.yaml

# --- Knowledge: deployment-specific raw source documents ---
# Operators keep their private knowledge files local; they are not portable.
# See examples/ for templates and the GUIDE.md for authoring guidelines.
knowledge/*.md
knowledge/*.txt

# --- Python ---
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.venv/
venv/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo

# --- OS ---
.DS_Store
Thumbs.db
